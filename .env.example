# Kopiere nach .env.local und trage echte Werte ein (nie committen).
# Ersetze re_xxxxxxxxx durch deinen API-Key aus dem Resend-Dashboard.

RESEND_API_KEY=re_xxxxxxxxx

# Optional: eigene verifizierte Domain in Resend, sonst Resend-Testabsender
# RESEND_FROM=Plesnicar Solutions <kontakt@deine-domain.at>

# Optional: Ziel-Adresse für Kontaktformular (Standard: plesnicaroffice@gmail.com)
# CONTACT_INBOX=borplepay@gmail.com
